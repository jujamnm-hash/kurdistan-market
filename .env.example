# Firebase Functions Environment Variables
# Set these using: firebase functions:config:set or in Firebase Console > Functions > Configuration

JWT_SECRET=your_strong_secret_here_min_32_chars
JWT_EXPIRE=30d

# Frontend (React) - add to frontend/.env.local
REACT_APP_FIREBASE_API_KEY=your_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id
REACT_APP_API_URL=https://europe-west1-YOUR_PROJECT_ID.cloudfunctions.net/api/api
