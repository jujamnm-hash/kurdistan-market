rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anyone can read sellers (needed for map + real-time updates)
    match /sellers/{sellerId} {
      allow read: if true;
      allow write: if false; // Only backend (Admin SDK) can write
    }
    // Travelers are private - only backend can access
    match /travelers/{travelerId} {
      allow read, write: if false;
    }
  }
}
