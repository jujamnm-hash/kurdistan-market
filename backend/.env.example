# Backend environment variables example
# Copy this to .env and fill in real values

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Your Cluster → Connect → Drivers
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/kurdistan_market?retryWrites=true&w=majority

# JWT secret - use a long random string in production
JWT_SECRET=change_this_to_a_very_long_random_secret_in_production
JWT_EXPIRE=7d

# Frontend URL for CORS (your Netlify URL after deployment)
FRONTEND_URL=https://your-app-name.netlify.app
